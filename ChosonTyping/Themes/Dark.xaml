<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 어두운 화면 — 먹 바탕, 같은 청·물빛의 조도만 올려서 -->
    <SolidColorBrush x:Key="Paper"      Color="#16130F"/>
    <SolidColorBrush x:Key="Ink"        Color="#ECE7DF"/>
    <SolidColorBrush x:Key="Mid"        Color="#9C948A"/>
    <SolidColorBrush x:Key="Faint"      Color="#6A6259"/>
    <SolidColorBrush x:Key="Hair"       Color="#2C2721"/>
    <SolidColorBrush x:Key="Soft"       Color="#201C17"/>
    <SolidColorBrush x:Key="Accent"     Color="#4577B5"/>
    <SolidColorBrush x:Key="AccentDeep" Color="#5C8CC9"/>
    <SolidColorBrush x:Key="Sky"        Color="#7FA6D2"/>
    <SolidColorBrush x:Key="Wrong"      Color="#7C726B"/>
</ResourceDictionary>
