<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 어두운 화면 — 어두운 회색 바탕, 청·물빛 강조 -->
    <SolidColorBrush x:Key="Paper"      Color="#282A2D"/>
    <SolidColorBrush x:Key="Ink"        Color="#ECEDEF"/>
    <SolidColorBrush x:Key="Mid"        Color="#9D9EA3"/>
    <SolidColorBrush x:Key="Faint"      Color="#6D6E73"/>
    <SolidColorBrush x:Key="Hair"       Color="#3D3F44"/>
    <SolidColorBrush x:Key="Soft"       Color="#313337"/>
    <SolidColorBrush x:Key="Accent"     Color="#5B88C2"/>
    <SolidColorBrush x:Key="AccentDeep" Color="#72A0D2"/>
    <SolidColorBrush x:Key="Sky"        Color="#88ACD6"/>
    <SolidColorBrush x:Key="Wrong"      Color="#E0605A"/>
</ResourceDictionary>
