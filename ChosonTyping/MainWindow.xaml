<Window x:Class="ChosonTyping.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="조선어 타자련습기" Width="1100" Height="800"
        MinWidth="980" MinHeight="700"
        Background="{StaticResource Paper}" FontFamily="{StaticResource Main}"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource Hair}"
                BorderThickness="0,0,0,1" Padding="40,16">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" FontSize="15" FontWeight="ExtraBold"
                           Foreground="{StaticResource Ink}">
                    <Run Text="조선어 타자련습기"/><Run Text="." Foreground="{StaticResource Red}"/>
                </TextBlock>
                <TextBlock HorizontalAlignment="Right" FontSize="12"
                           Foreground="{StaticResource Faint}" Text="판 0.1 · 포터블"/>
            </DockPanel>
        </Border>
        <ContentControl x:Name="Host"/>
    </DockPanel>
</Window>
