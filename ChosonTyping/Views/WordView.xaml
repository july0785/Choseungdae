<UserControl x:Class="ChosonTyping.Views.WordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ChosonTyping.Views"
             Focusable="True">
    <DockPanel>
        <views:StatsBar x:Name="Stats" DockPanel.Dock="Bottom"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,18,40,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource QuietButton}"
                            x:Name="BackBtn" HorizontalAlignment="Left" Click="Back_Click"/>
                    <TextBlock x:Name="TitleText" Grid.Column="1" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource Mid}" VerticalAlignment="Center"/>
                </Grid>

                <StackPanel x:Name="WordStack" Margin="0,26,0,20">
                    <TextBlock x:Name="TargetText" FontSize="52" FontWeight="ExtraBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="HintText" FontSize="13" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Faint}" Margin="0,14,0,0"/>
                </StackPanel>

                <views:KeyboardControl x:Name="Kb"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
