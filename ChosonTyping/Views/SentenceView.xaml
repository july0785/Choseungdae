<UserControl x:Class="ChosonTyping.Views.SentenceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ChosonTyping.Views"
             Focusable="True">
    <DockPanel>
        <views:StatsBar x:Name="Stats" DockPanel.Dock="Bottom"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,18,40,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource QuietButton}"
                            x:Name="BackBtn" HorizontalAlignment="Left" Click="Back_Click"/>
                    <TextBlock x:Name="TitleText" Grid.Column="1" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource Mid}" VerticalAlignment="Center"/>
                </Grid>

                <!-- 가사식 줄무더기: 지난 줄은 우로 흐리게, 다음 줄들은 아래로 점점 흐리게 -->
                <StackPanel x:Name="LyricStack" Margin="0,20,0,14">
                    <TextBlock x:Name="PrevLine" FontSize="15" Opacity="0.5"
                               Foreground="{DynamicResource Mid}" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock x:Name="TargetLine" FontSize="30" FontWeight="SemiBold"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock x:Name="NextLine" FontSize="15" Foreground="{DynamicResource Faint}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,24,0,0"/>
                    <TextBlock x:Name="NextLine2" FontSize="13" Opacity="0.55"
                               Foreground="{DynamicResource Faint}" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,7,0,0"/>
                </StackPanel>

                <views:KeyboardControl x:Name="Kb"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
