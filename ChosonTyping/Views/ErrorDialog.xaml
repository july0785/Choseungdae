<Window x:Class="ChosonTyping.Views.ErrorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="열기오유" WindowStyle="None" ResizeMode="NoResize"
        SizeToContent="Height" Width="480" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Paper}" FontFamily="{StaticResource Main}"
        ShowInTaskbar="False">
    <Border BorderBrush="{DynamicResource Hair}" BorderThickness="1" Padding="30,26,30,24">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="9" Height="9" Fill="{DynamicResource Wrong}" VerticalAlignment="Center"
                         Margin="0,0,10,0"/>
                <TextBlock x:Name="TitleTb" FontSize="18" FontWeight="ExtraBold"
                           Foreground="{DynamicResource Ink}"/>
            </StackPanel>
            <TextBlock x:Name="MessageText" FontSize="13.5" Foreground="{DynamicResource Mid}"
                       TextWrapping="Wrap" Margin="0,12,0,4" LineHeight="22"/>
            <Border BorderBrush="{DynamicResource Hair}" BorderThickness="0,1,0,0" Margin="0,12,0,0"
                    Padding="0,10,0,0">
                <TextBlock x:Name="SkipTb" FontSize="11.5"
                           Foreground="{DynamicResource Faint}"/>
            </Border>
            <Button x:Name="OkBtn" Style="{StaticResource AccentButton}" Padding="22,8"
                    HorizontalAlignment="Right" Margin="0,16,0,0" Click="Ok_Click"/>
        </StackPanel>
    </Border>
</Window>
