<Window x:Class="ChosonTyping.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="불러오기" WindowStyle="None" ResizeMode="NoResize"
        SizeToContent="Height" Width="440" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Paper}" FontFamily="{StaticResource Main}"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Paper}"/>
            <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Hair}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Ink}"/>
        </Style>
    </Window.Resources>
    <Border BorderBrush="{DynamicResource Hair}" BorderThickness="1" Padding="30,26,30,24">
        <StackPanel>
            <TextBlock x:Name="TitleTb" FontSize="18" FontWeight="ExtraBold"
                       Foreground="{DynamicResource Ink}"/>
            <TextBlock x:Name="NameLabel" Style="{StaticResource Label}" Margin="0,16,0,6"/>
            <TextBox x:Name="TitleBox"/>
            <TextBlock x:Name="SourceLabel" Style="{StaticResource Label}" Margin="0,12,0,6"/>
            <TextBox x:Name="SourceBox"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button x:Name="CancelBtn" Style="{StaticResource QuietButton}" Margin="0,0,12,0"
                        Click="Cancel_Click"/>
                <Button x:Name="SaveBtn" Style="{StaticResource AccentButton}" Padding="22,8"
                        Click="Ok_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
