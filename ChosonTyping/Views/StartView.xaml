<UserControl x:Class="ChosonTyping.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,20,40,40" MaxWidth="880">

            <DockPanel Margin="0,0,0,6">
                <StackPanel x:Name="LangBar" DockPanel.Dock="Right" Orientation="Horizontal"/>
                <TextBlock x:Name="LangLabel" Style="{StaticResource Label}" VerticalAlignment="Center"/>
            </DockPanel>

            <TextBlock x:Name="TitleText" Style="{StaticResource H1}" Margin="0,6,0,4"/>
            <TextBlock x:Name="SubText" Style="{StaticResource Body}" Foreground="{DynamicResource Mid}"
                       Margin="0,0,0,26"/>

            <TextBlock x:Name="LayoutsLabel" Style="{StaticResource Label}" Margin="0,0,0,10"/>
            <UniformGrid x:Name="LayoutCards" Columns="3"/>

            <TextBlock x:Name="StagesLabel" Style="{StaticResource Label}" Margin="0,28,0,10"/>
            <StackPanel x:Name="StageList"/>

            <Button x:Name="StartBtn" Style="{StaticResource AccentButton}"
                    HorizontalAlignment="Left" Margin="0,26,0,0" Click="StartBtn_Click"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
