<UserControl x:Class="ChosonTyping.Views.KeyDrillView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ChosonTyping.Views"
             Focusable="True">
    <DockPanel>
        <views:StatsBar x:Name="Stats" DockPanel.Dock="Bottom"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,18,40,24">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BackBtn" Grid.Column="0" Style="{StaticResource QuietButton}"
                            HorizontalAlignment="Left" Click="BackBtn_Click"/>
                    <TextBlock x:Name="TitleText" Grid.Column="1" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource Mid}" VerticalAlignment="Center"/>
                </Grid>

                <TextBlock x:Name="BigJamo" FontSize="84" FontWeight="ExtraBold"
                           Foreground="{DynamicResource Ink}" HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
                <TextBlock x:Name="HintText" FontSize="14" Foreground="{DynamicResource Mid}"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>

                <TextBlock x:Name="SeqText" FontSize="20" HorizontalAlignment="Center"
                           Margin="0,18,0,22"/>

                <views:KeyboardControl x:Name="Kb"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <StackPanel x:Name="LeftHand" Orientation="Horizontal" VerticalAlignment="Bottom"
                                Margin="0,0,28,0"/>
                    <StackPanel x:Name="RightHand" Orientation="Horizontal" VerticalAlignment="Bottom"/>
                </StackPanel>
                <TextBlock x:Name="HandCap" FontSize="12" Foreground="{DynamicResource Mid}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
