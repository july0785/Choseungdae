<UserControl x:Class="ChosonTyping.Views.AcidRainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ChosonTyping.Views"
             Focusable="True">
    <DockPanel>
        <views:StatsBar x:Name="Stats" DockPanel.Dock="Bottom"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,18,40,24">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="BackBtn" Style="{StaticResource QuietButton}" Click="Back_Click"/>
                        <TextBlock x:Name="TitleText" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource Mid}" VerticalAlignment="Center"
                                   Margin="16,0,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock x:Name="ScoreText" FontSize="13" Foreground="{DynamicResource Mid}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Border BorderBrush="{DynamicResource Hair}" BorderThickness="1" CornerRadius="10">
                    <Grid>
                        <Canvas x:Name="Field" Height="300" ClipToBounds="True"/>
                        <Border x:Name="GameOverPanel" Visibility="Collapsed"
                                Background="{DynamicResource Paper}" CornerRadius="10">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="OverTitle" FontSize="34" FontWeight="ExtraBold"
                                           Foreground="{DynamicResource Ink}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="OverDetail" FontSize="14" Foreground="{DynamicResource Mid}"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                <TextBlock x:Name="AgainText" FontSize="12"
                                           Foreground="{DynamicResource Faint}" HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                <Border BorderBrush="{DynamicResource Ink}" BorderThickness="0,0,0,2" Margin="60,10,60,4"
                        HorizontalAlignment="Stretch">
                    <TextBlock x:Name="InputText" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource Ink}" HorizontalAlignment="Center"
                               MinHeight="30" Padding="0,0,0,6"/>
                </Border>
                <Border Height="14"/>

                <views:KeyboardControl x:Name="Kb"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
